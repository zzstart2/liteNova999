# =============================================================================
# New-API Production Environment Variables
# Copy to .env and fill in real values: cp .env.example .env
# =============================================================================

# ====== Image ======
REPO_OWNER=zzstart2
VERSION=latest

# ====== Secrets (generate with: openssl rand -hex 32) ======
SESSION_SECRET=CHANGE_ME
CRYPTO_SECRET=CHANGE_ME
PG_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# ====== Database ======
SQL_DSN=postgresql://newapi:${PG_PASSWORD}@postgres:5432/newapi
# LOG_SQL_DSN=postgresql://newapi:${PG_PASSWORD}@pg-logs:5432/newapi_logs

# ====== Redis ======
REDIS_CONN_STRING=redis://:${REDIS_PASSWORD}@redis:6379/0
# REDIS_POOL_SIZE=10

# ====== Database Pool ======
SQL_MAX_IDLE_CONNS=100
SQL_MAX_OPEN_CONNS=1000
SQL_MAX_LIFETIME=60

# ====== Runtime ======
TZ=Asia/Shanghai
GIN_MODE=release
ERROR_LOG_ENABLED=true

# ====== Performance ======
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5
SYNC_FREQUENCY=60
STREAMING_TIMEOUT=300
RELAY_TIMEOUT=60

# ====== Channel Monitoring ======
CHANNEL_TEST_FREQUENCY=10
POLLING_INTERVAL=2

# ====== Data Export ======
DATA_EXPORT_ENABLED=true
DATA_EXPORT_INTERVAL=5

# ====== Profiling (optional) ======
# ENABLE_PPROF=true
# PYROSCOPE_URL=http://pyroscope:4040
# PYROSCOPE_APP_NAME=new-api
